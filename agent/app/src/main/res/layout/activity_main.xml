<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sinun"
                android:textColor="#E6EDF3"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v0.1.0"
                android:textColor="#3D444D"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ===== אשף התקנה מודרך (מוצג רק בזמן ההגדרה הראשונית) ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/setup_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="14dp"
            app:strokeColor="#1F6FEB"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:id="@+id/setup_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שלב 1 מתוך 4"
                    android:textColor="#58A6FF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:id="@+id/setup_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#E6EDF3"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:id="@+id/setup_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#8B949E"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="22dp" />
                <Button
                    android:id="@+id/btn_setup_continue"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="#1F6FEB"
                    android:text="@string/setup_continue"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/setup_progress_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#5A6478"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="14dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="#F85149" />
                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_unprotected"
                        android:textColor="#E6EDF3"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/policy_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/policy_none"
                    android:textColor="#8B949E"
                    android:textSize="13sp"
                    android:layout_marginBottom="18dp" />
                <Button
                    android:id="@+id/btn_start_vpn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#3B82F6"
                    android:text="@string/btn_start_protection"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/perms_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perms_title"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btn_usage_access"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/perm_usage_missing" />
                <Button
                    android:id="@+id/btn_overlay"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/perm_overlay_missing" />
                <Button
                    android:id="@+id/btn_device_admin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_admin_missing" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/request_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_request_opening"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btn_request_opening"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_request_opening" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/removal_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1118"
            app:cardCornerRadius="12dp"
            app:strokeColor="#3D2B2B"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_request_removal"
                    android:textColor="#8B4451"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btn_request_removal"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/btn_request_removal" />
                <Button
                    android:id="@+id/btn_enter_removal_code"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_enter_removal_code" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
